import java.util.Random;
import java.util.Scanner;
public class NumberGame {
	public static void main(String[] args) {
		// TODO Auto-generated method stub
		        Scanner sc = new Scanner(System.in);
		        Random random = new Random();
		        int totalScore = 0;
		        String play;
		        System.out.println("***NUMBER GAME***");
		        do {
		            System.out.println("\nChoose Difficulty:");
		            System.out.println("1. Easy (1-50, 10 Attempts only)");
		            System.out.println("2. Medium (1-100, 7 Attempts only)");
		            System.out.println("3. Hard (1-200, 5 Attempts only)");
		            System.out.print("Enter Choice: ");
		            int choice = sc.nextInt();
		            int range = 100;
		            int maxAttempts = 7;
		            switch (choice) {
		                case 1:
		                    range = 50;
		                    maxAttempts = 10;
		                    break;
		                case 2:
		                    range = 100;
		                    maxAttempts = 7;
		                    break;
		                case 3:
		                    range = 200;
		                    maxAttempts = 5;
		                    break;
		                default:
		                    System.out.println("Invalid Choice! Medium Mode Selected.");
		            }
		            int secretNumber = random.nextInt(range) + 1;
		            boolean won = false;

		            System.out.println("\nGuess the number between 1 and " + range);

		            for (int attempt = 1; attempt <= maxAttempts; attempt++) {

		                System.out.print("Attempt " + attempt + ": ");
		                int guess = sc.nextInt();
		                if (guess == secretNumber) {
		                    System.out.println("Correct! You found the number.");
		                    int score = (maxAttempts - attempt + 1) * 10;
		                    totalScore += score;
		                    System.out.println("Round Score: " + score);
		                    won = true;
		                    break;
		                }
		                int difference = Math.abs(secretNumber - guess);

		                if (difference <= 5)
		                    System.out.println("Very Close!");
		                else if (difference <= 15)
		                    System.out.println("Close!");
		                else
		                    System.out.println("Far Away!");

		                if (guess < secretNumber)
		                    System.out.println("Hint: Try Higher");
		                else
		                    System.out.println("Hint: Try Lower");
		            }

		            if (!won) {
		                System.out.println("You Lost!");
		                System.out.println("Correct Number: " + secretNumber);
		            }

		            System.out.println("Total Score: " + totalScore);

		            System.out.print("\nPlay Again? (yes/no): ");
		            play = sc.next();

		        } while (play.equalsIgnoreCase("yes"));

		        System.out.println("\nFinal Score: " + totalScore);
		        System.out.println("Thank You for Playing!");
		        sc.close();
		    }
		}

	
